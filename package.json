{
  "name": "vein-launch",
  "version": "1.3.1",
  "description": "SOTA Claude Code launcher with 7-tier precheck, CLIProxy management, and quality gates",
  "type": "module",
  "bin": {
    "vein": "./bin/vein.cmd"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "vitest run evals/deepeval/",
    "eval:legacy": "promptfoo eval -c evals/promptfooconfig.yaml",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "npx lefthook install"
  },
  "files": [
    "bin/",
    "src/",
    "config/",
    "docs/sota-installed-manifest.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "launcher",
    "precheck",
    "cli",
    "developer-tools"
  ],
  "author": "seath",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "deepeval": "^0.1.29",
    "promptfoo": "0.121.12",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  }
}
